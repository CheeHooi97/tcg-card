package repository

import (
	"errors"
	"pkm/model"

	"gorm.io/gorm"
)

type CGCRepository interface {
	Create(auth *model.CGC) error
	GetById(id string) (*model.CGC, error)
	CheckCardNameAndCardNumberAndSetNameAndRarity(cardName, cardNumber, setName, rarity string) bool
	GetByCardNameAndCardNumberAndSetNameAndRarity(cardName, cardNumber, setName, rarity string) (*model.CGC, error)
	GetDetailByCardNameAndCardNumberAndSetName(cardName, cardNumber, setName string) (*model.CGC, error)
	GetByCardNumberAndSetNumber(cardNumber, setNumber string) (*model.CGC, error)
	GetAllCards() ([]*model.CGC, error)
	Update(auth *model.CGC) error
	Delete(id string) error
}

type cgcRepository struct {
	db *gorm.DB
}

func NewCGCRepository(db *gorm.DB) CGCRepository {
	return &cgcRepository{db: db}
}

func (r *cgcRepository) Create(auth *model.CGC) error {
	result := r.db.Create(auth)
	if result.Error != nil {
		return result.Error
	}
	return nil
}

func (r *cgcRepository) GetById(id string) (*model.CGC, error) {
	var auth model.CGC
	result := r.db.First(&auth, id)
	if result.Error != nil {
		if !errors.Is(result.Error, gorm.ErrRecordNotFound) {
			return nil, result.Error
		}
	}
	return &auth, nil
}

func (r *cgcRepository) CheckCardNameAndCardNumberAndSetNameAndRarity(cardName, cardNumber, setName, rarity string) bool {
	var auth model.CGC
	result := r.db.
		Where("cardName = ? AND cardNumber = ? AND setName = ? AND rarity = ?", cardName, cardNumber, setName, rarity).
		First(&auth)
	if result.Error != nil {
		if errors.Is(result.Error, gorm.ErrRecordNotFound) {
			return false
		}
	}
	return true
}

func (r *cgcRepository) GetByCardNameAndCardNumberAndSetNameAndRarity(cardName, cardNumber, setName, rarity string) (*model.CGC, error) {
	var cgc model.CGC
	result := r.db.
		Where("cardName = ? AND cardNumber = ? AND setName = ? AND rarity = ?", cardName, cardNumber, setName, rarity).
		First(&cgc)
	if result.Error != nil {
		if !errors.Is(result.Error, gorm.ErrRecordNotFound) {
			return nil, result.Error
		}
	}
	return &cgc, nil
}

func (r *cgcRepository) GetDetailByCardNameAndCardNumberAndSetName(cardName, cardNumber, setName string) (*model.CGC, error) {
	var cgc model.CGC
	result := r.db.
		Where("cardName LIKE ? AND cardNumber LIKE ? AND setName LIKE ?", "%"+cardName+"%", "%"+cardNumber+"%", "%"+setName+"%").
		First(&cgc)
	if result.Error != nil {
		if !errors.Is(result.Error, gorm.ErrRecordNotFound) {
			return nil, result.Error
		}
	}
	return &cgc, nil
}

func (r *cgcRepository) GetByCardNumberAndSetNumber(cardNumber, setNumber string) (*model.CGC, error) {
	var cgc model.CGC
	result := r.db.
		Where("cardNumber = ? AND setNumber = ?", cardNumber, setNumber).
		First(&cgc)
	if result.Error != nil {
		if !errors.Is(result.Error, gorm.ErrRecordNotFound) {
			return nil, result.Error
		}
	}
	return &cgc, nil
}

func (r *cgcRepository) GetAllCards() ([]*model.CGC, error) {
	var cgc []*model.CGC
	result := r.db.
		Order("createdDateTime ASC").
		Find(&cgc)
	if result.Error != nil {
		if !errors.Is(result.Error, gorm.ErrRecordNotFound) {
			return nil, result.Error
		}
	}
	return cgc, nil
}

func (r *cgcRepository) Update(auth *model.CGC) error {
	result := r.db.Save(auth)
	if result.Error != nil {
		return result.Error
	}
	return nil
}

func (r *cgcRepository) Delete(id string) error {
	result := r.db.Model(&model.CGC{}).Where("id = ?", id).Update("status", false)
	return result.Error
}
